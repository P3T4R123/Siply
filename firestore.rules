rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function cafe(cafeId) {
      return get(/databases/$(database)/documents/cafes/$(cafeId));
    }

    function cafeAfter(cafeId) {
      return getAfter(/databases/$(database)/documents/cafes/$(cafeId));
    }

    function invite(cafeId, inviteCode) {
      return get(/databases/$(database)/documents/cafes/$(cafeId)/invites/$(inviteCode));
    }

    function isMember(cafeId) {
      return signedIn()
        && exists(/databases/$(database)/documents/cafes/$(cafeId)/members/$(request.auth.uid));
    }

    function isAdmin(cafeId) {
      return isMember(cafeId)
        && get(/databases/$(database)/documents/cafes/$(cafeId)/members/$(request.auth.uid)).data.role == "admin";
    }

    function hasValidAdminInvite(cafeId) {
      return signedIn()
        && request.resource.data.inviteCode is string
        && exists(/databases/$(database)/documents/cafes/$(cafeId)/invites/$(request.resource.data.inviteCode))
        && invite(cafeId, request.resource.data.inviteCode).data.active == true
        && invite(cafeId, request.resource.data.inviteCode).data.role == "admin";
    }

    match /cafes/{cafeId} {
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.name is string;

      allow get: if signedIn();
      allow list: if false;
      allow update, delete: if isAdmin(cafeId);

      match /members/{uid} {
        allow get: if signedIn() && (request.auth.uid == uid || isAdmin(cafeId));
        allow list: if isAdmin(cafeId);

        allow create: if signedIn()
          && request.auth.uid == uid
          && request.resource.data.uid == uid
          && request.resource.data.name is string
          && (
            (
              request.resource.data.role == "admin"
              && (
                cafeAfter(cafeId).data.ownerUid == request.auth.uid
                || hasValidAdminInvite(cafeId)
              )
            )
            || (
              request.resource.data.role == "waiter"
              && exists(/databases/$(database)/documents/cafes/$(cafeId))
            )
          );

        allow update, delete: if isAdmin(cafeId);
      }

      match /invites/{inviteCode} {
        allow get: if signedIn();
        allow list: if isAdmin(cafeId);
        allow create: if isAdmin(cafeId)
          || (signedIn() && cafeAfter(cafeId).data.ownerUid == request.auth.uid);
        allow update, delete: if isAdmin(cafeId);
      }

      match /catalogProducts/{productId} {
        allow get, list: if isMember(cafeId);

        allow create: if isAdmin(cafeId)
          && request.resource.data.name is string
          && request.resource.data.priceCents is int
          && request.resource.data.categoryId is int
          && request.resource.data.createdByUid == request.auth.uid;

        allow update, delete: if isAdmin(cafeId);
      }

      match /receipts/{receiptId} {
        allow get, list: if isAdmin(cafeId);

        allow create: if isMember(cafeId)
          && request.resource.data.waiterId == request.auth.uid
          && request.resource.data.waiterName is string
          && request.resource.data.totalCents is int
          && request.resource.data.createdAt is int
          && request.resource.data.items is list;

        allow update: if false;
        allow delete: if isAdmin(cafeId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
